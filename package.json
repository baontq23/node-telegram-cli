{
  "name": "node-telegram-cli",
  "version": "1.3.0",
  "description": "A powerful CLI tool to access your Telegram account. Send/read messages, manage groups, search, and more via MTProto.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ntg": "./bin/ntg.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "telegram",
    "cli",
    "mtproto",
    "telegram-client",
    "messaging",
    "chat",
    "terminal",
    "node-telegram"
  ],
  "author": "baontq23",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baontq23/node-telegram-cli.git"
  },
  "bugs": {
    "url": "https://github.com/baontq23/node-telegram-cli/issues"
  },
  "homepage": "https://github.com/baontq23/node-telegram-cli#readme",
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "input": "^1.0.1",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
